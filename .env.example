META_ACCESS_TOKEN=YOUR_META_ACCESS_TOKEN
META_AD_ACCOUNT_ID=act_YOUR_AD_ACCOUNT_ID
META_API_VERSION=v19.0

# Snowflake 접속 정보
SNOWFLAKE_ACCOUNT=your_account.region          # 예: abc12345.ap-northeast-1
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_WAREHOUSE=your_warehouse
SNOWFLAKE_DATABASE=your_database
SNOWFLAKE_SCHEMA=your_schema
SNOWFLAKE_ROLE=PU_PF
SNOWFLAKE_TABLE=META_AD_SNAPSHOT

# Gemini AI 설정
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# 이메일 Alert 설정 (Office365 STARTTLS)
SMTP_SERVER=smtp.office365.com
SMTP_PORT=587
SMTP_USER=ghseol@fnfcorp.com
SMTP_PASSWORD=your_password
ALERT_RECIPIENTS=recipient1@fnfcorp.com,recipient2@fnfcorp.com
